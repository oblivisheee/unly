# Unly Agent Platform — Environment Variables
# Copy this file to /etc/unly/unly.env and fill in your values.
# This file contains secrets and must NOT be committed to version control.
# Recommended permissions: chmod 600 /etc/unly/unly.env

# === Telegram ===
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram numeric user ID (from @userinfobot)
TELEGRAM_ADMIN_USER_IDS=123456789

# === Database ===
# Override database path (optional, default is config.toml value)
# UNLY_DATABASE_PATH=/opt/unly/data/unly.sqlite

# === Provider API Keys ===
# GitHub Copilot auth is via the device flow (`unly provider-login copilot`)
# and does not require env vars. If you have a GitHub PAT with Copilot access:
# GITHUB_TOKEN=ghp_your_token_here

# OpenAI-compatible provider keys (if configured in config.toml)
# OPENAI_API_KEY=sk-your_key_here

# === Webhook Secret ===
# UNLY_WEBHOOK_SECRET=your_webhook_secret_here

# === Logging ===
RUST_LOG=info
